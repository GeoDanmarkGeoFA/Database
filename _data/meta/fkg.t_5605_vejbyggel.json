    "properties": {
        "formaal": "Oplyse sagsbehandler og borger via selvbetjeningsl\u00f8sninger, hvor der noglebyggelinjer og evt. givet dispensationer.",
        "temakode": "5605",
        "temanavn": "Trafik_byggelinje",
        "kle_koder": "05.01.11",
        "meta_desc": "<p>\nViser hvor der er vejbyggelinjer og givet dispensationer. Herunder ogs\u00e5 hvor dispensationen er givet med en fjernelse betingelse. \nDette vil altid kun v\u00e6re et vejledende tema. Det er tinglysningen m.v. der g\u00e6lder.\n\n<\/p>\n<p>\n  Vil du vide mere? P\u00e5 \n  <a href=\"https:\/\/confluence.sdfi.dk\/pages\/viewpage.action?pageId=191398876\" target=\"_blank\">\n    confluence \n  <\/a> \n  finder du GeoFA\u2019s vejledningsunivers \u2013 tag et kig.\n<\/p>",
        "definition": "Vejbyggelinjer p\u00e5lagt efter vejloven eller planloven, langs veje samt dispensationer fra disse byggelinjer.",
        "noegle_ord": "Byggeri, tinglysning, Deklaration, Oversigtsareal",
        "beskrivelse": "Viser hvor der er vejbyggelinjer og givet dispensationer. Herunder ogs\u00e5 hvor dispensationen er givet med en fjernelse betingelse. Dette vil altid kun v\u00e6re et vejledende tema. Det er tinglysningen m.v. der g\u00e6lder.",
        "lovgrundlag": "Vejloven",
        "geometritype": "Flade",
        "max_features": "500",
        "default_match": "any",
        "load_strategy": "s",
        "vidi_layer_type": "t,v",
