    "properties": {
        "formaal": "Skabe overblik over hvad de kommunale ejendomme er udlejet til og hvor l\u00e6nge.",
        "temakode": "5705",
        "temanavn": "Forpagtningsareal",
        "kle_koder": "13.06.03",
        "meta_desc": "<p>\n\nlaget viser kommunale arealer som udlejes\/forpagtes. Herunder marker, ejendomme, cirkuspladser. <\/p>\n<p>\n  Vil du vide mere? P\u00e5 \n  <a href=\"https:\/\/confluence.sdfi.dk\/pages\/viewpage.action?pageId=191398876\" target=\"_blank\">\n    confluence \n  <\/a> \n  finder du GeoFA\u2019s vejledningsunivers \u2013 tag et kig.\n<\/p>",
        "definition": "Kommunale arealer som udlejes\/forpagtes.",
        "noegle_ord": "Udlejning, forpagtning",
        "beskrivelse": "Marker, ejendomme, cirkuspladser som udlejes\/forpagtes til anden side. ",
