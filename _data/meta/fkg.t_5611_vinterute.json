        "geometrisk_konsistens": "Se GeoDanmark-specifikationen",
        "noegleord_hovedgruppe": "Transportnet, Offentlig forsyningsvirksomhed og offentlige tjenesteydelser",
        "registreringsinstruks": "GeoDanmark-vejmidte geometrien benyttes eller tilsvarende tema fra f.eks. Vejman eller ROSY.",
        "klassificering_opdeling": "Ruterne b\u00f8r opdeles efter om ruten er p\u00e5 vej, p\u00e5 sti eller er en \u201dmanuel\/mandskabsrute\u201d. Denne har \nbetydning for hvilket materiel og hvilken type kontrakt der skal indg\u00e5s. ",
        "max_zoom_level_table_click": "17",
        "geometrisk_konsistens_andre": "Se GeoDanmark-specifikationen"
    },
